# ──────────────────────────────────────────────────────
# Example Terraform variable values
# Copy to terraform.tfvars and fill in your values
# ──────────────────────────────────────────────────────

subscription_id                      = "PLACEHOLDER"
resource_group_name                  = "jf-token-rotation"
location                             = "East US"

# Key Vault
key_vault_name                       = "artifactory-access-token-kv"

# Artifactory
artifactory_url                      = "https://avivka2.jfrog.io"
jfrog_oidc_provider_name             = "PLACEHOLDER"
azure_ad_token_audience              = "api://PLACEHOLDER"
artifactory_token_secret_name        = "artifactory-access-token-secret"

# Function App
function_app_name                    = "artifactory-token-rotation"
storage_account_name                 = "artifactory-token-rotation-code"

# Optional: user-assigned managed identity
# user_assigned_identity_name        = "my-function-identity"
# existing_user_assigned_identity_id = "/subscriptions/.../resourceGroups/.../providers/Microsoft.ManagedIdentity/userAssignedIdentities/..."
