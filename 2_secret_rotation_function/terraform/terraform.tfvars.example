# ──────────────────────────────────────────────────────
# Example Terraform variable values
# Copy to terraform.tfvars and fill in your values
# ──────────────────────────────────────────────────────

subscription_id     = "YOUR_AZURE_SUBSCRIPTION_ID"
resource_group_name = "YOUR_RESOURCE_GROUP"
# location            = "Sweden Central"

# Existing Azure ML workspace Key Vault (data source only; not created by this Terraform)
key_vault_name = "YOUR_AML_WORKSPACE_KEY_VAULT_NAME"
# key_vault_resource_group_name = "YOUR_KEY_VAULT_RG"  # optional; defaults to resource_group_name

# Existing Azure ML workspace Storage Account (data source only; a new container is created for the function)
existing_storage_account_name = "YOUR_AML_WORKSPACE_STORAGE_ACCOUNT_NAME"
# existing_storage_resource_group_name = "YOUR_STORAGE_RG"  # optional; defaults to resource_group_name
# function_storage_container_name = "azure-function-token-rotation"  # dedicated container for the function

# Artifactory / token rotation
artifactory_url          = "https://yourorg.jfrog.io"
jfrog_oidc_provider_name = "YOUR_OIDC_PROVIDER_NAME"
azure_ad_token_audience  = "YOUR_APP_REGISTRATION_CLIENT_ID"
# artifactory_token_secret_name = "artifactory-access-token-secret"
# Set to have Terraform create the secret in Key Vault with that name; leave unset to create it manually by key Vault Admin
# artifactory_token_initial_value = "YOUR_INITIAL_TOKEN_OR_PLACEHOLDER"
# secret_ttl = "21600"  # seconds (6 hours)

# Function App
function_app_name = "artifactory-token-rotation"
# function_python_version = "3.13"

# VNet integration (optional): existing subnet with (1) delegation Microsoft.Web/serverFarms,
# (2) service_endpoints = ["Microsoft.Storage", "Microsoft.KeyVault"], (3) same region as function app
# function_app_integration_subnet_id = "/subscriptions/YOUR_SUB/resourceGroups/YOUR_RG/providers/Microsoft.Network/virtualNetworks/YOUR_VNET/subnets/YOUR_SUBNET"

# CIDR ranges allowed to access Function App SCM for zip deployment (e.g. [\"1.2.3.4/32\"])
# deployer_ip_addresses = ["1.2.3.4/32", "NAT_IP"]

# Application Insights (optional; leave unset or empty to disable)
# application_insights_connection_string = "InstrumentationKey=...;IngestionEndpoint=...;..."
# application_insights_key               = "YOUR_INSTRUMENTATION_KEY"

# Tags (optional)
# tags = {
#  project     = "jfrog-azureml-integration"
#  managed_by  = "terraform"
#  environment = "dev"
#  application = "azureml"
# }
